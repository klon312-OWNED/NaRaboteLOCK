{
  "name": "narabote",
  "version": "1.0.0",
  "description": "НаРаботе — учёт рабочего времени, отпусков и графиков сотрудников (Electron + xlsx)",
  "author": {
    "name": "Антипин Андрей Александрович",
    "email": "Skilleforsken@gmail.com"
  },
  "license": "SEE LICENSE IN LICENSE",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "create-test": "node scripts/create_test_data.js",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "dist": "electron-builder --win --linux"
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "ru.narabote.app",
    "productName": "НаРаботе",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "config.json",
      "LICENSE",
      "lib/**/*",
      "renderer/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "data",
        "to": "data",
        "filter": [
          "users.json"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": [
        "ru"
      ],
      "language": "1049",
      "shortcutName": "НаРаботе"
    },
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Office",
      "maintainer": "Антипин Андрей Александрович <Skilleforsken@gmail.com>"
    }
  }
}
